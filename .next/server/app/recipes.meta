{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/recipes/layout,_N_T_/(app)/recipes/page,_N_T_/recipes"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/recipes/__PAGE__",
    "/!KGFwcCk/recipes",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}